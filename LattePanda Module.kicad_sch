	(text "HSIO functions are defined by the BIOS source code, \r\nCannot be changed in BIOS settings.\r\n\r\nBefore starting design, you should choose one of\r\nthe available BIOS configurations on:\r\nhttps://github.com/LattePandaTeam/LattePanda-Mu\r\nOr contact techsupport for custom your BIOS\r\n\r\nThe default functions are defined as follows:\r\n\r\n- HSIO0: USB3.2 10Gbps\r\n- HSIO1: USB3.2 10Gbps\r\n- HSIO2: PCIe 3.0 x1\r\n- HSIO3: PCIe 3.0 x1\r\n\r\n- HSIO8: PCIe 3.0 x4 (Lane 0)\r\n- HSIO9: PCIe 3.0 x4 (Lane 1)\r\n- HSIO10: PCIe 3.0 x4 (Lane 2)\r\n- HSIO11: PCIe 3.0 x4 (Lane 3)\r\n\r\n- HSIO6: PCIe 3.0 x1"
		(exclude_from_sim no)
		(at 19.19 207.909 0)
		(effects
			(font
				(size 2.159 2.159)
				(thickness 0.4318)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "1a7629b9-73f5-425f-b493-25ad4327f615")
	)
	(text "HPD pin of unused DDI/TCP port\r\nneeds to be pulled down"
		(exclude_from_sim no)
		(at 177.8 346.329 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "1b2cb61a-6cf1-4b37-b85b-c4014f802890")
	)
	(text "DDI/TCP functions are defined by the BIOS source code, \r\nCannot be changed in BIOS settings.\r\n\r\nBefore starting design, you should choose one of\r\nthe available BIOS configurations on:\r\nhttps://github.com/LattePandaTeam/LattePanda-Mu\r\n\r\nThe default functions are defined as follows:\r\n\r\n- DDIA: eDP 1.4b (the 40Pin connector on the Mu)\r\n\r\n- DDIB: HDMI 2.0\r\n\r\n- TCP0: HDMI 2.0\r\n\r\n- TCP1: USB TypeC (need external PD controller)"
		(exclude_from_sim no)
		(at 20 309.989 0)
		(effects
			(font
				(size 2.159 2.159)
				(thickness 0.4318)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "1ccdaf8c-7e08-44de-b740-4481b0f2ac5e")
	)
	(text "SPI is only used to connect to the BIOS ROM and discrete TPM\r\nCannot be used as a general SPI interface."
		(exclude_from_sim no)
		(at 355.6 291.084 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "79cf9ccb-efaa-43dc-a30f-a7604f27e528")
	)
	(text "~{CLKREQ} is reserved for PCIe ASPM L1s\r\nUnless the device clearly supports it, pull it down to enhance compatibility"
		(exclude_from_sim no)
		(at 370.84 162.179 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "9bac5c73-c9aa-46dc-a2c6-4bef5b38ae91")
	)
	(text "Sleeping State Signal\r\n\r\n- SLS_S0: \r\n  - S0 (Working): HIGH\r\n  - S3 (Slpeeping): LOW\r\n  - S4 (Hibernation): LOW\r\n  - S5 (Soft Off): LOW\r\n- SLS_S3:\r\n  - S0 (Working): HIGH\r\n  - S3 (Slpeeping): HIGH\r\n  - S4 (Hibernation): LOW\r\n  - S5 (Soft Off): LOW"
		(exclude_from_sim no)
		(at 114.3 205.994 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "9e2d2156-e0f8-4120-ab2e-f234f4e4570c")
	)
	(text "Lite Carrier has no second BIOS ROM\r\n~{BIOS_SEL} pull up to 3.3V to select ROM on LattePanda Mu"
		(exclude_from_sim no)
		(at 355.6 303.784 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left bottom)
		)
		(uuid "b9c56bc2-a5e2-4ae3-a998-f7c920944536")
	)
	(text "USB2_P6 is reserved for TypeC PD Controller\r\nDO NOT use it as a normal USB"
